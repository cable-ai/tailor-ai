# eBay API Keys (Sandbox - for testing)
EBAY_SANDBOX_CLIENT_ID=your_sandbox_client_id_here
EBAY_SANDBOX_CLIENT_SECRET=your_sandbox_client_secret_here
EBAY_SANDBOX_REDIRECT_URI=http://localhost:4000/api/auth/ebay/callback
EBAY_VERIFICATION_TOKEN=your_verification_token_here
EBAY_NOTIFICATION_ENDPOINT_URL=https://yourdomain.com/api/marketplace/account-deletion

# eBay API Keys (Production - for live listings)
EBAY_PROD_CLIENT_ID=your_prod_client_id_here
EBAY_PROD_CLIENT_SECRET=your_prod_client_secret_here
EBAY_PROD_REDIRECT_URI=https://yourdomain.com/auth/ebay/callback

# Anthropic Claude API
ANTHROPIC_API_KEY=your_api_key_here

# Database (PostgreSQL via Supabase)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Redis (for caching and rate limiting via Upstash)
REDIS_URL=redis://:password@host:port

# Stripe (for payment processing - Phase 2)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Application Environment
NODE_ENV=development
MOCK_EBAY=false      # Set to true to bypass eBay OAuth and fake publish (dev only)
API_PORT=4000
API_URL=http://localhost:4000

# Frontend (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:8081

# Optional: Sentry (error tracking - Phase 2)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/12345

# Optional: Analytics (Phase 2)
ANALYTICS_ID=your_analytics_id
